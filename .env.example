# =============================================================
# Auth Service — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com credenciais reais!
# =============================================================

# ----- Servidor -----
AUTH_PORT=8081

# ----- Banco de Dados (PostgreSQL) -----
# Local:  postgresql://postgres:senha@localhost:5432/auth_db?sslmode=disable
# Prod:   postgresql://user:senha@host/db?sslmode=require&channel_binding=require
AUTH_DB_DSN=postgresql://postgres:sua_senha_aqui@localhost:5432/auth_db?sslmode=disable

# ----- Redis -----
# Local:  redis://localhost:6379
# Prod:   rediss://default:senha@host.upstash.io:6379/0
AUTH_REDIS_ADDR=redis://localhost:6379

# ----- JWT (RS256 — chave privada RSA) -----
# Use scripts/generate_keys.sh para gerar as chaves
JWT_PRIVATE_KEY_PATH=keys/private.pem
# Alternativa (para Docker/CI): conteúdo PEM inline
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...

# ----- MFA (TOTP) -----
# Chave AES-256 para encriptar segredos TOTP (mínimo 32 caracteres)
# Gere com: openssl rand -base64 32
MFA_ENCRYPTION_KEY=troque_por_uma_chave_de_32_chars_minimo

# ----- Issuer (identifica o serviço nos JWT e TOTP) -----
AUTH_ISSUER=auth-service

# ----- Docker Compose -----
POSTGRES_USER=authuser
POSTGRES_PASSWORD=troque_por_senha_forte
POSTGRES_DB=authdb
